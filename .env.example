# ═══════════════════════════════════════════════════════
# Smart Scalper Bot - Environment Variables
# ═══════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env

# ── مفاتيح Alpaca API ──────────────────────────────────
ALPACA_API_KEY=YOUR_API_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_KEY_HERE

# ── إعدادات النشر ───────────────────────────────────────
PORT=8080

# ── تشغيل تلقائي ────────────────────────────────────────
# true = البوت يبدأ التداول تلقائياً عند تشغيل السيرفر
# false = يجب الضغط على "تشغيل" من لوحة التحكم
AUTO_START_TRADING=true

# ── إعادة تشغيل تلقائي عند التعطل ────────────────────────
AUTO_RESTART_ON_CRASH=true
MAX_RESTART_ATTEMPTS=10
